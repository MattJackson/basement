{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "gen:api": "openapi-typescript ../openapi/basement.yaml -o src/shared/api/types.gen.ts",
    "gen:routes": "tsr generate",
    "prebuild": "pnpm run gen:api && pnpm run gen:routes",
    "predev": "pnpm run gen:api && pnpm run gen:routes",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node -e \"require('fs').closeSync(require('fs').openSync('../internal/web/dist/.gitkeep','a'))\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "smoke": "bash ../scripts/postdeploy-ui-smoke.sh",
    "smoke:full": "bash ../scripts/comprehensive-smoke.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-virtual": "^3.13.26",
    "@tanstack/router-plugin": "^1.168.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^17.0.8",
    "shadcn": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/router-cli": "^1.167.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "i18next-resources-to-backend": "^1.2.1",
    "jsdom": "^29.1.1",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "^4.1.7",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [],
    "ignoredBuiltDependencies": [
      "msw"
    ]
  }
}
