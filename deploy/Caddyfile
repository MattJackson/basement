# basement — reference Caddyfile
#
# Hostnames + upstreams are substituted from environment variables at
# Caddy startup. Set them in deploy/.env (consumed by docker-compose).
#
# Two hosts:
#   {$BASEMENT_HOSTNAME}  → basement (UI + API, same port)
#   {$S3_HOSTNAME}        → Garage S3 data plane
#
# CRITICAL: the s3 vhost must preserve the Host header — Garage's SigV4
# validates against the host the client signed. Caddy's reverse_proxy
# preserves Host by default, but we set it explicitly so the contract is
# unmistakable in code review.

{$BASEMENT_HOSTNAME} {
    encode zstd gzip
    reverse_proxy basement:8080
}

{$S3_HOSTNAME} {
    # Generous body size + timeouts for multi-GB PUTs and slow uploaders.
    request_body {
        max_size 5GB
    }
    reverse_proxy {$GARAGE_S3_UPSTREAM} {
        header_up Host {http.request.host}
        transport http {
            response_header_timeout 5m
            read_timeout 30m
        }
    }
}
