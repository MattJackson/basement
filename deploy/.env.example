# basement Docker Compose Environment File
# Copy this file to .env and edit the CHANGE_ME values before running docker compose up

# =============================================================================
# Server Configuration (required: none, recommended: all)
# =============================================================================

# TCP address to listen on. Default ":8080" if not set.
BASEMENT_LISTEN=:8080

# Directory for JSON store (users, grants, shares) and audit logs.
# Must be writable by the container user (nobody:65532).
BASEMENT_DATA_DIR=/var/lib/basement

# Absolute base URL for share links. If set, used to generate absolute URLs
# in /share/:token redirects. Optional but recommended for production.
# Example: https://basement.example.com
# BASEMENT_PUBLIC_URL=

# Log level: debug, info (default), warn, error
BASEMENT_LOG_LEVEL=info

# Session sliding TTL as Go duration string (e.g., 1h, 30m, 24h). Default 24h.
# BASEMENT_SESSION_TTL=24h

# Days to retain audit logs before cleanup. Integer default 90.
# BASEMENT_AUDIT_RETENTION_DAYS=90


# =============================================================================
# Driver Configuration (required: all when DRIVER=garage)
# =============================================================================

# Backend driver name. Only "garage" supported in v1.0.
BASEMENT_DRIVER=garage

# Garage Admin API URL (e.g., http://garage:3903). Required if DRIVER=garage.
BASEMENT_DRIVER_GARAGE_ADMIN_URL=http://garage:3903

# Bearer token for Garage admin API. Required if DRIVER=garage.
# Get this from your Garage cluster's admin tokens (v2 endpoint).
# CHANGE_ME: Set your Garage admin token here
BASEMENT_DRIVER_GARAGE_ADMIN_TOKEN=CHANGE_ME

# S3 data-plane URL (e.g., http://garage:3900). Optional if only admin ops needed.
BASEMENT_DRIVER_GARAGE_S3_URL=http://garage:3900

# S3 region name (e.g., garage). Used in SigV4 signing.
BASEMENT_DRIVER_GARAGE_S3_REGION=garage

# S3 access key for data-plane operations (buckets, objects). Optional.
# CHANGE_ME: Set your S3 access key here
BASEMENT_DRIVER_GARAGE_S3_ACCESS_KEY=CHANGE_ME

# S3 secret key for data-plane operations. Optional.
# CHANGE_ME: Set your S3 secret key here
BASEMENT_DRIVER_GARAGE_S3_SECRET_KEY=CHANGE_ME


# =============================================================================
# Admin Authentication (v1.0 — required)
# =============================================================================

# Admin username (single admin account in v1.0).
# CHANGE_ME: Set your admin username here
BASEMENT_ADMIN_USER=admin

# bcrypt hash of admin password. Generate with:
#   echo "your-password" | bcrypt -g 12
# Or Node.js: node -e 'const bcrypt=require("bcrypt"); console.log(bcrypt.hashSync("your-password", 12))'
# CHANGE_ME: Set your bcrypt password hash here
BASEMENT_ADMIN_PASSWORD_HASH=CHANGE_ME

# Secret for signing HS256 JWTs. Must be >=32 bytes after base64 decoding.
# Generate with: openssl rand -base64 32
# Or Node.js: node -e 'console.log(require("crypto").randomBytes(32).toString("base64"))'
# CHANGE_ME: Set your JWT secret here (96 chars from openssl rand -base64 32)
BASEMENT_JWT_SECRET=CHANGE_ME


# =============================================================================
# OIDC Configuration (v1.3+ — optional, not enabled in v1.0)
# =============================================================================

# OIDC issuer URL (e.g., https://auth.example.com). Optional; only used if v1.3+ enabled.
# BASEMENT_OIDC_ISSUER=

# OIDC client ID from issuer registration. Optional.
# BASEMENT_OIDC_CLIENT_ID=

# OIDC client secret from issuer registration. Optional.
# BASEMENT_OIDC_CLIENT_SECRET=

# Auto-create local user on first OIDC login if no matching username exists. Default false.
# BASEMENT_OIDC_AUTO_PROVISION=false


# =============================================================================
# Caddy (consumed by deploy/Caddyfile via env interpolation)
# =============================================================================

# Hostnames the Caddyfile substitutes. Must match what you set DNS for.
BASEMENT_HOSTNAME=basement.example.com
S3_HOSTNAME=s3.example.com

# Upstream Caddy forwards s3.example.com to — typically Garage:3900.
GARAGE_S3_UPSTREAM=garage:3900


# =============================================================================
# Notes
# =============================================================================

# - All CHANGE_ME values MUST be set before starting the container.
# - The Garage admin token (BASEMENT_DRIVER_GARAGE_ADMIN_TOKEN) is different from
#   S3 credentials — it's for the admin API, not the data plane.
# - If you're using docker-compose, ensure the garage service is started first
#   (depends_on in docker-compose.yml handles this).
# - For Caddy reverse proxy setup, see deploy/Caddyfile and README.md.
